pkgbase = mandrel-bin
	pkgdesc = Downstream distribution of GraalVM CE serving as the native-image builder for Quarkus
	pkgver = 25.0.3.0
	pkgrel = 1
	url = https://github.com/graalvm/mandrel
	install = install_mandrel.sh
	arch = x86_64
	arch = aarch64
	license = custom
	depends = ca-certificates-java
	depends = java-runtime-common
	depends = java-environment-common
	depends = freetype2
	depends = glibc
	depends = libgcc
	depends = libstdc++
	depends = libz.so
	optdepends = alsa-lib: for basic sound support
	optdepends = libx11: for AWT support
	optdepends = libxext: for AWT support
	optdepends = libxi: for AWT support
	optdepends = libxrender: for AWT support
	optdepends = libxtst: for AWT support
	provides = java-runtime=25
	provides = java-runtime-headless=25
	provides = java-environment=25
	provides = mandrel
	options = staticlibs
	options = !debug
	options = !strip
